5. Pass and Return Objects in Complex Class.

#include <iostream>
using namespace std;

class Complex 
{
    float real, imag;

public:
    void setComplex(float r,float i) 
    {
        real = r;
        imag = i;
    }

    void displayComplex() 
    {
        cout<<real<<" + "<<imag<<"i\n";
    }

    Complex add(Complex C) 
    {
        Complex x;
        x.real = real + C.real;
        x.imag = imag + C.imag;
        return x;
    }
};

int main() 
{
    Complex c1, c2, c3;

    c1.setComplex(2.5, 3.5);
    c2.setComplex(1.5, 4.5);

    c3=c1.add(c2);

    cout<<"Sum = ";
    c3.displayComplex();
    return 0;
}

6. Implementing Scope Resolution Operator (::).

#include <iostream>
using namespace std;

int x=10;   

class Scope 
{
public:
    static int y;
    void show();
};

int Scope::y = 20;

void Scope::show() 
{
    int x=5;
    cout<<"Local x = "<<x<<endl;
    cout<<"Global x = "<<::x<<endl;
    cout<<"Static y = "<<Scope::y<<endl;
}

int main() 
{
    Scope S;
    S.show();
    return 0;
}

