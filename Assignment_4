4. Dynamic memory allocation (new & delete).

#include <iostream>
using namespace std;

class Demo 
{
public:
    int x;

    Demo(int val) 
    {
        x = val;
    }

    void display() 
    {
        cout<<"Value = "<<x<<endl;
    }
};

int main() 
{
    int *p = new int;
    *p = 10;
    cout << "Integer: " << *p << endl;
    delete p;

    float *f = new float;
    *f = 5.5;
    cout << "Float: " << *f << endl;
    delete f;

    int *arr = new int[3];
    arr[0] = 1; arr[1] = 2; arr[2] = 3;
    cout << "Integer Array: ";
    for(int i=0;i<3;i++) cout << arr[i] << " ";
    cout<<endl;
    delete[] arr;

    float *farr = new float[3];
    farr[0] = 1.1; farr[1] = 2.2; farr[2] = 3.3;
    cout << "Float Array: ";
    for(int i=0;i<3;i++) cout << farr[i] << " ";
    cout<<endl;
    delete[] farr;

    Demo *obj = new Demo(50);
    obj->display();
    delete obj;

    Demo *objArr = new Demo[2] { Demo(10), Demo(20) };
    for(int i=0;i<2;i++) 
    {
        objArr[i].display();
    }
    delete[] objArr;

    return 0;
}
