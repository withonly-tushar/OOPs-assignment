1. Basic Inheritance (Base + Derived).

#include <iostream>
using namespace std;

class Base {
public:
    void showBase() {
        cout << "This is Base class" << endl;
    }
};

class Derived : public Base {
public:
    void showDerived() {
        cout << "This is Derived class" << endl;
    }
};

int main() {
    Base b;
    Derived d;

    b.showBase();
    d.showBase();
    d.showDerived();

    return 0;
}

2. Protected Access Specifier.

#include <iostream>
using namespace std;

class Base {
protected:
    int x;
};

class Derived : public Base {
public:
    void setValue(int a) {
        x = a;
    }
    void display() {
        cout << "Value of x = " << x << endl;
    }
};

int main() {
    Derived d;
    d.setValue(10);
    d.display();

    return 0;
}

3. Public vs Protected vs Private Inheritance.

#include <iostream>
using namespace std;

class Base {
public:
    int a = 10;
};

class PublicDerived : public Base {
};

class ProtectedDerived : protected Base {
public:
    void show() {
        cout << "Protected Inheritance: " << a << endl;
    }
};

class PrivateDerived : private Base {
public:
    void show() {
        cout << "Private Inheritance: " << a << endl;
    }
};

int main() {
    PublicDerived p;
    cout << "Public Inheritance: " << p.a << endl;

    ProtectedDerived pr;
    pr.show();

    PrivateDerived pv;
    pv.show();

    return 0;
}

