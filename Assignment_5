    r.display();

    return 0;
}

10. Hybrid Inheritance (Person, Staff, Student, TA).

#include <iostream>
using namespace std;

class Person {
protected:
    string name;
public:
    void setName(string n) { name = n; }
};

class Staff : public Person {
protected:
    int emp_id;
public:
    void setStaff(int id) { emp_id = id; }
};

class Student : public Person {
protected:
    int student_id;
public:
    void setStudent(int id) { student_id = id; }
};

class TeachingAssistant : public Staff, public Student {
public:
    void display() {
        cout << "Name: " << Staff::name << endl;
        cout << "Emp ID: " << emp_id << endl;
        cout << "Student ID: " << student_id << endl;
    }
};

int main() {
    TeachingAssistant ta;
    ta.Staff::setName("Arsh");
    ta.setStaff(101);
    ta.setStudent(202);

    ta.display();

    return 0;
}
