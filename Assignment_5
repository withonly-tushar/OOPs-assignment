6. Book & Textbook (Single Inheritance).

#include <iostream>
using namespace std;

class Book {
protected:
    string title, author;
    float price;

public:
    void setBook(string t, string a, float p) {
        title = t;
        author = a;
        price = p;
    }

    void displayBook() {
        cout << "Title: " << title << "\nAuthor: " << author << "\nPrice: " << price << endl;
    }
};

class Textbook : public Book {
    string subject;

public:
    void setTextbook(string t, string a, float p, string s) {
        setBook(t, a, p);
        subject = s;
    }

    void displayTextbook() {
        displayBook();
        cout << "Subject: " << subject << endl;
    }
};

int main() {
    Textbook t;
    t.setTextbook("Maths", "Author A", 500, "Algebra");
    t.displayTextbook();

    return 0;
}

7. Car Dashboard (Multiple Inheritance).

#include <iostream>
using namespace std;

class Speedometer {
protected:
    int speed;
public:
    void setSpeed(int s) { speed = s; }
};

class FuelGauge {
protected:
    int fuel;
public:
    void setFuel(int f) { fuel = f; }
};

class Thermometer {
protected:
    int temp;
public:
    void setTemp(int t) { temp = t; }
};

class CarDashboard : public Speedometer, public FuelGauge, public Thermometer {
public:
    void display() {
        cout << "Speed: " << speed << endl;
        cout << "Fuel: " << fuel << endl;
        cout << "Temperature: " << temp << endl;
    }
};

int main() {
    CarDashboard c;
    c.setSpeed(80);
    c.setFuel(50);
    c.setTemp(90);
    c.display();

    return 0;
}

8. Library System (Hierarchical Inheritance).

#include <iostream>
using namespace std;

class LibraryUser {
protected:
    string name;
    int id;

public:
    void setUser(string n, int i) {
        name = n;
        id = i;
    }
};

class Student : public LibraryUser {
    int grade;
public:
    void setStudent(string n, int i, int g) {
        setUser(n, i);
        grade = g;
    }
    void display() {
        cout << "Student: " << name << ", ID: " << id << ", Grade: " << grade << endl;
    }
};

class Teacher : public LibraryUser {
    string dept;
public:
    void setTeacher(string n, int i, string d) {
        setUser(n, i);
        dept = d;
    }
    void display() {
        cout << "Teacher: " << name << ", ID: " << id << ", Dept: " << dept << endl;
    }
};

int main() {
    Student s;
    Teacher t;

    s.setStudent("Arsh", 1, 12);
    t.setTeacher("Sir", 2, "CSE");

    s.display();
    t.display();

    return 0;
}

