Function Templates

1. Swap Two Variables#include <iostream>
using namespace std;

template <class T>
void swapValues(T &a, T &b) {
    T temp = a;
    a = b;
    b = temp;
}

int main() {
    int x = 5, y = 10;
    swapValues(x, y);
    cout << "After swap: " << x << " " << y;
    return 0;
}

2. Minimum Element in Array.

#include <iostream>
using namespace std;

template <class T>
T findMin(T arr[], int n) {
    T min = arr[0];
    for(int i = 1; i < n; i++) {
        if(arr[i] < min)
            min = arr[i];
    }
    return min;
}

int main() {
    int arr[] = {5, 2, 8, 1, 3};
    cout << "Minimum: " << findMin(arr, 5);
    return 0;
}

3. Bubble Sort Template.

#include <iostream>
using namespace std;

template <class T>
void bubbleSort(T arr[], int n) {
    for(int i = 0; i < n-1; i++) {
        for(int j = 0; j < n-i-1; j++) {
            if(arr[j] > arr[j+1]) {
                T temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
        }
    }
}

int main() {
    int arr[] = {5, 3, 8, 1};
    bubbleSort(arr, 4);

    for(int i = 0; i < 4; i++)
        cout << arr[i] << " ";
    return 0;
}

4. Linear Search Template.

#include <iostream>
using namespace std;

template <class T>
int linearSearch(T arr[], int n, T key) {
    for(int i = 0; i < n; i++) {
        if(arr[i] == key)
            return i;
    }
    return -1;
}

int main() {
    int arr[] = {10, 20, 30, 40};
    int index = linearSearch(arr, 4, 30);

    if(index != -1)
        cout << "Found at index: " << index;
    else
        cout << "Not found";
    return 0;
}

5. Overloaded Function Template process().

#include <iostream>
using namespace std;

template <class T>
void process(T a) {
    cout << "Single parameter: " << a << endl;
}

template <class T>
void process(T a, T b) {
    cout << "Same type: " << a << " " << b << endl;
}

template <class T, class U>
void process(T a, U b) {
    cout << "Different types: " << a << " " << b << endl;
}

int main() {
    process(5);
    process(5, 10);
    process(5, 3.14);
    return 0;
}

Class Templates

1. Stack Template.

#include <iostream>
using namespace std;

template <class T>
class Stack {
    T arr[100];
    int top;
public:
    Stack() { top = -1; }

    void push(T x) {
        arr[++top] = x;
    }

    void pop() {
        if(top >= 0)
            top--;
        else
            cout << "Stack Underflow\n";
    }

    void display() {
        for(int i = 0; i <= top; i++)
            cout << arr[i] << " ";
    }
};

int main() {
    Stack<int> s;
    s.push(10);
    s.push(20);
    s.display();
    return 0;
}

2. Queue Template.

#include <iostream>
using namespace std;

template <class T>
class Queue {
    T arr[100];
    int front, rear;
public:
    Queue() { front = 0; rear = -1; }

    void enqueue(T x) {
        arr[++rear] = x;
    }

    void dequeue() {
        if(front <= rear)
            front++;
        else
            cout << "Queue Underflow\n";
    }

    void display() {
        for(int i = front; i <= rear; i++)
            cout << arr[i] << " ";
    }
};

int main() {
    Queue<int> q;
    q.enqueue(10);
    q.enqueue(20);
    q.display();
    return 0;
}

