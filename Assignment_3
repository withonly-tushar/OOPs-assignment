1. Pointer to object + this pointer + . and ->.

#include <iostream>
using namespace std;

class Pointers 
{
public:
    int x;

    void setData(int x) 
    {
        this->x = x;   
    }

    void display() 
    {
        cout<<"Value: "<<x<<endl;
    }
};

int main()  
{
    Pointers obj;
    Pointers *ptr;

    ptr=&obj;

    obj.setData(10);    
    obj.display();

    ptr->setData(20);   
    ptr->display();

    return 0;
}

2. Swap private values using friend function.

#include <iostream>
using namespace std;

class A 
{
private:
    int x;
public:
    A(int a) { x = a; }
    friend void swap(A &, B &);
    void show() 
    { cout<<"A: "<<x<<endl; }
};

class B 
{
private:
    int y;
public:
    B(int b) { y = b; }
    friend void swap(A &, B &);
    void show() 
    { cout<<"B: "<<y<<endl; }
};

void swap(A &obj1, B &obj2) 
{
    int temp = obj1.x;
    obj1.x = obj2.y;
    obj2.y = temp;
}

int main() 
{
    A obj1(10);
    B obj2(20);

    swap(obj1, obj2);

    obj1.show();
    obj2.show();

    return 0;
}

3. Add objects of two different classes using friend function.

#include <iostream>
using namespace std;

class A 
{
private:
    int x;
public:
    A(int a) { x = a; }
    friend int add(A, B);
};

class B 
{
private:
    int y;
public:
    B(int b) { y = b; }
    friend int add(A, B);
};

int add(A obj1, B obj2) 
{
    return obj1.x + obj2.y;
}

int main() 
{
    A obj1(5);
    B obj2(10);

    cout<<"Sum = "<<add(obj1, obj2);

    return 0;
}

