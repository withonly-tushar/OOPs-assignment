{
    int n = 3;
    cout<<"Cube = "<<cube(n);

    return 0;
}

7(a). Pass object by value and return object.

#include <iostream>
using namespace std;

class Demo 
{
public:
    int x;

    Demo(int a) { x = a; }

    Demo add(Demo obj) 
    {
        return Demo(x + obj.x);
    }

    void show() 
    {
        cout<<"Value: "<<x<<endl;
    }
};

int main() 
{
    Demo d1(10), d2(20), d3(0);

    d3 = d1.add(d2);

    d3.show();

    return 0;
}

7(b). Pass object by address (pointer) and return object.

#include <iostream>
using namespace std;

class Demo 
{
public:
    int x;

    Demo(int a) { x = a; }

    Demo add(Demo *obj) 
    {
        return Demo(x + obj->x);
    }

    void show() 
    {
        cout<<"Value: "<<x<<endl;
    }
};

int main() 
{
    Demo d1(10), d2(20), d3(0);

    d3 = d1.add(&d2);

    d3.show();

    return 0;
}
